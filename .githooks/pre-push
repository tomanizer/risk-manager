#!/usr/bin/env bash
# pre-push hook — mirrors the lint-and-test CI job.
#
# Runs on every `git push`.  Install once per clone:
#   git config core.hooksPath .githooks
#
# To skip in an emergency:
#   git push --no-verify
set -euo pipefail

# ---------------------------------------------------------------------------
# Locate Python / virtual-env
# ---------------------------------------------------------------------------
REPO_ROOT="$(git rev-parse --show-toplevel)"
VENV_PYTHON=""
for candidate in \
    "$REPO_ROOT/.venv/bin/python" \
    "$REPO_ROOT/.venv/bin/python3" \
    "python3" \
    "python"; do
    if command -v "$candidate" &>/dev/null 2>&1 || [ -x "$candidate" ]; then
        VENV_PYTHON="$candidate"
        break
    fi
done

if [ -z "$VENV_PYTHON" ]; then
    echo "pre-push: cannot find Python — skipping lint checks." >&2
    exit 0
fi

# Check whether ruff / mypy are actually available before running them.
has_tool() { "$VENV_PYTHON" -c "import $1" 2>/dev/null; }

# ---------------------------------------------------------------------------
# Collect tracked Python files
# ---------------------------------------------------------------------------
PY_FILES="$(git ls-files '*.py' '*.pyi' 2>/dev/null | head -1)"
if [ -z "$PY_FILES" ]; then
    echo "pre-push: no Python files tracked — nothing to check."
    exit 0
fi

cd "$REPO_ROOT"

FAILED=0

# ---------------------------------------------------------------------------
# 1. Ruff lint
# ---------------------------------------------------------------------------
if has_tool ruff; then
    echo "pre-push: ruff check …"
    if ! "$VENV_PYTHON" -m ruff check .; then
        echo ""
        echo "pre-push: ✗ ruff check failed — fix the errors above before pushing." >&2
        FAILED=1
    fi
else
    echo "pre-push: ruff not found in venv — skipping lint check." >&2
fi

# ---------------------------------------------------------------------------
# 2. Ruff format
# ---------------------------------------------------------------------------
if has_tool ruff; then
    echo "pre-push: ruff format --check …"
    if ! "$VENV_PYTHON" -m ruff format --check .; then
        echo ""
        echo "pre-push: ✗ ruff format check failed." >&2
        echo "         Run:  .venv/bin/python -m ruff format ." >&2
        FAILED=1
    fi
fi

# ---------------------------------------------------------------------------
# 3. Mypy
# ---------------------------------------------------------------------------
if has_tool mypy; then
    echo "pre-push: mypy …"
    if ! "$VENV_PYTHON" -m mypy src/ agent_runtime/; then
        echo ""
        echo "pre-push: ✗ mypy failed — fix the type errors above before pushing." >&2
        FAILED=1
    fi
else
    echo "pre-push: mypy not found in venv — skipping type check." >&2
fi

# ---------------------------------------------------------------------------
# Result
# ---------------------------------------------------------------------------
if [ "$FAILED" -ne 0 ]; then
    echo ""
    echo "pre-push: one or more checks failed.  Push blocked." >&2
    echo "         To bypass: git push --no-verify" >&2
    exit 1
fi

echo "pre-push: all checks passed."
