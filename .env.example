# =============================================================================
# risk-manager — environment configuration template
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# .env is gitignored and must NEVER be committed.
# All keys are optional; the runtime skips providers that have no key set.
# =============================================================================


# -----------------------------------------------------------------------------
# OpenAI
# Docs: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_ORGANIZATION=org-...         # optional org ID
# OPENAI_BASE_URL=                    # override for proxies / Azure OpenAI
# OPENAI_MODEL=gpt-4o                 # default inference model
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small


# -----------------------------------------------------------------------------
# Anthropic / Claude
# Docs: https://console.anthropic.com/keys
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=                 # override for proxies
# ANTHROPIC_MODEL=claude-opus-4-5


# -----------------------------------------------------------------------------
# Google Gemini
# Docs: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
# GEMINI_API_KEY=AIza...
# GOOGLE_API_KEY=AIza...              # accepted alias for GEMINI_API_KEY
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_EMBEDDING_MODEL=models/text-embedding-004


# -----------------------------------------------------------------------------
# Cursor AI
# Docs: https://cursor.sh
# -----------------------------------------------------------------------------
# CURSOR_API_KEY=
# CURSOR_BASE_URL=https://api.cursor.sh/v1
# CURSOR_MODEL=cursor-fast


# -----------------------------------------------------------------------------
# LangChain / LangSmith  (tracing & evaluation)
# Docs: https://smith.langchain.com
# -----------------------------------------------------------------------------
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_TRACING_V2=true           # set to true to enable LangSmith tracing
# LANGCHAIN_PROJECT=risk-manager
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com


# -----------------------------------------------------------------------------
# LangGraph Cloud / self-hosted
# Docs: https://langchain-ai.github.io/langgraph/cloud/
# -----------------------------------------------------------------------------
# LANGGRAPH_API_KEY=
# LANGGRAPH_API_URL=https://your-deployment.langgraph.app
# LANGGRAPH_GRAPH_ID=


# -----------------------------------------------------------------------------
# Agent Runtime backends
# Docs: agent_runtime/README.md
# Default backend is "prepared" (manual handoff — safe default, no API keys
# required).  Set a role's _BACKEND to one of:
#   codex_exec    — Codex CLI subprocess (requires `codex` on PATH)
#   openai_api    — OpenAI SDK  (requires OPENAI_API_KEY + pip install .[sdk])
#   anthropic_api — Anthropic SDK (requires ANTHROPIC_API_KEY + pip install .[sdk])
#   cursor_api    — Cursor API  (requires CURSOR_API_KEY + pip install .[sdk]; WI-C)
# -----------------------------------------------------------------------------
# AGENT_RUNTIME_PM_BACKEND=prepared
# AGENT_RUNTIME_PM_CODEX_BIN=codex
# AGENT_RUNTIME_PM_CODEX_MODEL=gpt-5
# AGENT_RUNTIME_PM_OPENAI_MODEL=gpt-4o
# AGENT_RUNTIME_PM_ANTHROPIC_MODEL=claude-sonnet-4-5
# AGENT_RUNTIME_PM_CURSOR_MODEL=cursor-fast

# AGENT_RUNTIME_REVIEW_BACKEND=prepared
# AGENT_RUNTIME_REVIEW_CODEX_BIN=codex
# AGENT_RUNTIME_REVIEW_CODEX_MODEL=gpt-5
# AGENT_RUNTIME_REVIEW_OPENAI_MODEL=gpt-4o
# AGENT_RUNTIME_REVIEW_ANTHROPIC_MODEL=claude-sonnet-4-5
# AGENT_RUNTIME_REVIEW_CURSOR_MODEL=cursor-fast

# AGENT_RUNTIME_CODING_BACKEND=prepared
# AGENT_RUNTIME_CODING_CODEX_BIN=codex
# AGENT_RUNTIME_CODING_CODEX_MODEL=gpt-5
# AGENT_RUNTIME_CODING_OPENAI_MODEL=gpt-4o
# AGENT_RUNTIME_CODING_ANTHROPIC_MODEL=claude-sonnet-4-5
# AGENT_RUNTIME_CODING_CURSOR_MODEL=cursor-fast
# AGENT_RUNTIME_CODING_TOOL_MAX_ITERATIONS=50

# AGENT_RUNTIME_SPEC_BACKEND=prepared
# AGENT_RUNTIME_SPEC_CODEX_BIN=codex
# AGENT_RUNTIME_SPEC_CODEX_MODEL=gpt-5
# AGENT_RUNTIME_SPEC_OPENAI_MODEL=gpt-4o
# AGENT_RUNTIME_SPEC_ANTHROPIC_MODEL=claude-sonnet-4-5
# AGENT_RUNTIME_SPEC_CURSOR_MODEL=cursor-fast

# AGENT_RUNTIME_CODING_PR_BACKEND=gh_draft   # auto-publish draft PRs after coding
# AGENT_RUNTIME_CODING_PR_TITLE_PREFIX=[codex]

# AGENT_RUNTIME_AUTO_MERGE=false             # squash-merge approved PRs automatically
# AGENT_RUNTIME_AUTO_PROMOTE_WI=false        # move WI to done/ after merge
